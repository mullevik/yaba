#:kivy 1.0.9
#:import Factory kivy.factory.Factory

<YetAnotherBudgetApp>:
    orientation: "vertical"
    Label:
        text: "Sample header"
        background_color: 1, 0, 0, 1
        color: 0, 0, 1, 1
        font_size: '15sp'
        size_hint_y: None
        height: self.texture_size[1] + dp(10)
    TransactionHistory:
        id: history
    
    Button:
        text: "New Transaction"
        on_release: Factory.NewTransactionPopup().open()
        size_hint_y: None


<TransactionHistory>:
    viewclass: 'TransactionItem'
    orientation: "vertical"
    spacing: 10
    padding: 10, 10
  
    RecycleBoxLayout:
        # defines the size of the widget in reference to width and height
        default_size_hint: 1., None
        size_hint_y: None
        size_hint_x: 1.
        height: self.minimum_height
        orientation: 'vertical'


<TransactionItem@Label>:
    color: 0, 1, 0, 1
    canvas.before:
        Color:
            rgba: 0.5, 0.5, 0.5, 1
        Rectangle:
            pos: self.pos
            size: self.size

<NewTransactionPopup@Popup>:
    auto_dismiss: False
    title: "Add new item"

    Button:
        text: 'Add random!'
        on_release: root.on_add_item()
        size_hint_y: None
